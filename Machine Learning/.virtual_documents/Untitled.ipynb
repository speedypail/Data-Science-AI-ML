import pandas as pd
df=pd.read_csv('Employee_Salary.csv')
print(df)


df.shape


df.head()


df.info()


df.describe()


X=df[['experience_years']]
y=df['salary']


import matplotlib.pyplot as plt
plt.scatter(df['experience_years'],df['salary'])
plt.xlabel('Experience')
plt.ylabel('Salary')
plt.title('Experience Vs Salary')
plt.show()


from sklearn.preprocessing import PolynomialFeatures
poly=PolynomialFeatures(degree=2)
X_poly=poly.fit_transform(X)


from sklearn.model_selection import train_test_split
X_train,X_test,y_train,y_test=train_test_split(X_poly,y,test_size=0.2,random_state=42)


from sklearn.linear_model import LinearRegression
model=LinearRegression()
model.fit(X_train,y_train)


from sklearn.metrics import mean_squared_error,r2_score
y_pred=model.predict(X_test)
mse=mean_squared_error(y_test,y_pred)
r2=r2_score(y_test,y_pred)
print('Mean Squared Error:',mse)
print('R2 Score:',r2)


new_exp=pd.DataFrame({
    'experience_years':[2,5,10,15,18]
})
new_exp_poly=poly.transform(new_exp)
predicted_salary=model.predict(new_exp_poly)
results=pd.DataFrame({
    'Experience (Years)':new_exp['experience_years'],
    'Predicted Salary':predicted_salary
})
print(results)



