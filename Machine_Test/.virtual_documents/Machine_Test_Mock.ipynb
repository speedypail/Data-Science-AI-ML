# Load all Datasets
import pandas as pd
import matplotlib.pyplot as plt
data1=pd.read_excel("students.xlsx")
df1=pd.DataFrame(data1)
print("Student Dataset\n")
print(df1)
data2=pd.read_excel("courses.xlsx")
df2=pd.DataFrame(data2)
print("Courses Dataset\n")
print(df2)
data3=pd.read_excel("Enrollements.xlsx")
df3=pd.DataFrame(data3)
print("Enrollements Dataset\n")
print(df3)


print("Number of rows and columns of first dataset:", df1.shape)
print("Number of rows and columns of second dataset:",df2.shape)
print("Number of rows and columns of third dataset:", df3.shape)


print("The first 5 rows of students dataset is:\n",df1.head())


print("The first 5 rows of courses dataset is:\n",df2.head())


print("The first 5 rows of enrollement dataset is:\n",df3.head())


df3['EnrollmentDate'] = pd.to_datetime(df3['EnrollmentDate'])
plt.plot(df3['EnrollmentDate'],df3['StudentID'])
plt.show()


plt.figure(figsize=(12, 6))
plt.bar(df1['StudentName'],df1['City'])
plt.show()


plt.figure(figsize=(12,6))
plt.bar(df2['Category'],df2['Fee'])
plt.tight_layout()
plt.show()


top_courses = (
    df2['CourseName']
    .value_counts()
)

top_courses.plot(kind='bar')

plt.title("Top Courses by Enrollment")
plt.xlabel("Course")
plt.ylabel("Enrollments")
plt.show()



