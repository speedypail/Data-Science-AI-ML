import seaborn as sns
import matplotlib.pyplot as plt
iris=sns.load_dataset('iris')
print(iris.head())



sns.pairplot(iris,hue='species')
plt.show()


tips=sns.load_dataset('tips')
sns.relplot(data=tips,x='total_bill',y='tip',row='sex',col='time',hue='smoker')
max_tip = tips['tip'].max()
max_row = tips[tips['tip'] == max_tip].iloc[0]
plt.annotate(
    "Highest Tip",
    xy=(max_row["total_bill"], max_row["tip"]),
    xytext=(max_row["total_bill"] + 5, max_row["tip"] + 1),
    arrowprops={"arrowstyle": "->"})
plt.grid(True)
plt.suptitle('Management Analytics Dashboard')
plt.show()



