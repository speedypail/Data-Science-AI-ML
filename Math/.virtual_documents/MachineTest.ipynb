# Question 1
# To find the square of a number from user input
def square(x):
    return x**2
x=int(input('Enter the value of x:'))
result=square(x)
print('The Square of',x,'is:',result)


# To find the cube of a number from user input
def cube(x):
    return x**3
x=int(input('Enter the value of x: '))
result=cube(x)
print('The cube of',x,'is: ',result)


# To find the average of 3 numbers from user input
def average(a,b,c):
    return (a+b+c)/3
a=int(input('Enter the value of a: '))
b=int(input('Enter the value of b: '))
c=int(input('Enter the value of c: '))
result=average(a,b,c)
print('The average of 3 numbers is: ',result)


