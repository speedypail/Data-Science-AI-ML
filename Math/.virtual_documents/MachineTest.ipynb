# Question 8
df4=pd.read_excel('probability_data.xlsx')
print(df4)
experiment = df4["Experiment"][0]
print("Experiment =", experiment)
outcomes = df4["Outcome"].unique()
print("Outcomes =", outcomes)
heads = (df4["Outcome"] == "Head").sum()
tails = (df4["Outcome"] == "Tail").sum()
total = len(df4)
probability1 = heads / total
probability2 = tails / total
print("Number of Heads =", heads)
print("Number of Tails =", tails)
print("Total Outcomes =", total)
print("Probability of Head =", probability1)
print("Probability of Tail =", probability2)


# Question 9
import random
outcome=[]
for i in range(10):
    toss=random.choice(['Head','Tail'])
    outcome.append(toss)
print(outcome)
heads=outcome.count('Head')
tails=outcome.count('Tail')
total=len(outcome)
print("Probability of Head =", heads / total)
print("Probability of Tail =", tails / total)


# Question 10
import numpy as np
df5=pd.read_excel('vector_data.xlsx')
print(df5)
for index,rows in df5.iterrows():
    x=rows['X']
    y=rows['Y']
    vector=np.array([x,y])
    scalar_vector=2*vector
    magnitude=np.linalg.norm(vector)
    print("\n", rows['Vector'])
    print("Original Vector:", vector)
    print("Scalar Multiplication :", scalar_vector)
    print("Magnitude:", magnitude)


v1=np.array([df5.loc[0,'X'],df5.loc[0,'Y']])
v2=np.array([df5.loc[1,'X'],df5.loc[1,'Y']])
add=v1+v2
print('Addition of two vectors is: ',add)


# Question 11
df6=pd.read_excel('matrix_data.xlsx')
print(df6)


for index,rows in df6.iterrows():
    M11=rows['m11']
    M12=rows['m12']
    M21=rows['m21']
    M22=rows['m22']
    matrix=np.array([[M11,M12],[M21,M22]])
    shape=matrix.shape
    print('Shape of the matrix is: ',shape)
    print('\n')
    scalar=5*matrix
    print('Scalar Matrix', scalar)
    transpose=matrix.T
    print('Transpose of the matrix: \n',transpose)


# Matrix Addition
