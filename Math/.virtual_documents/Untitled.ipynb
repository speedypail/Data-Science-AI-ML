import numpy as np
sales = [12, 15, 18, 20, 15, 22, 25, 15, 28, 30]
mean=np.mean(sales)
print(mean)


median=np.median(sales)
print(median)


import statistics as st
sales.sort()
mode=st.mode(sales)
print(mode)


var=np.var(sales)
print(var)


std=np.std(sales)
print(std)


sales.append(200)
print(sales)


mean=np.mean(sales)
print(mean)


median=np.median(sales)
print(median)



