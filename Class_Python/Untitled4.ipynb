   "source": [
    "import cupy as cp\n",
    "import time\n",
    "\n",
    "start = time.time()\n",
    "\n",
    "a = cp.random.rand(5000, 5000)\n",
    "b = cp.random.rand(5000, 5000)\n",
    "\n",
    "c = cp.dot(a, b)\n",
    "\n",
    "# Wait for GPU computation to finish\n",
    "cp.cuda.Stream.null.synchronize()\n",
    "\n",
    "print(\"Shape:\", c.shape)\n",
    "print(\"Time:\", time.time() - start, \"seconds\")"
   ]
