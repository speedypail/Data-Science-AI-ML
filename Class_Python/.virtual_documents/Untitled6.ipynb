import pandas as pd

data = {
    "id": [1,2,3,4,5,6,7,8],
    "name": ["John","Emma","Raj","Sophia","Arun","Mia","Vinay","Lily"],
    "age": [28,32,26,29,35,31,27,30],
    "salary": [54000,72000,48000,61000,82000,69000,50000,58000],
    "department": ["Sales","Marketing","IT","Sales","Finance","IT","Marketing","Finance"]
}

df = pd.DataFrame(data)
df.to_csv("sample_data.csv", index=False)
print("CSV created successfully!")


import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# Load CSV data into Pandas
df = pd.read_csv("sample_data.csv")

# Create a Seaborn plot
sns.barplot(data=df, x="department", y="salary")
plt.show()


import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt

# Load only the salary column (4th column) from CSV into NumPy
data = np.loadtxt("sample_data.csv", delimiter=",", skiprows=1, usecols=3)

# Plot using Seaborn
sns.histplot(data)
plt.show()



