plt.title("Graph of y = 2x")
plt.show()


def salary(hours):
    return 500 * hours

for h in range(1, 5):
    print("Hours:", h, "Salary:", salary(h))


# Two points on a line
x1, y1 = 2, 4

x2, y2 = 6, 12

slope = (y2 - y1) / (x2 - x1)
print("Slope:", slope)



def total_cost(items):
    return 50 + 20 * items  # 50 is base cost

print(total_cost(0))
print(total_cost(3))


