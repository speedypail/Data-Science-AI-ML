import matplotlib.pyplot as plt
plt.style.use("seaborn-v0_8")
x = [1, 2, 3, 4]
y = [12, 18, 25, 35]
plt.plot(x, y, linewidth=2)
plt.title("Quarterly Performance", fontsize=14)
plt.xlabel("Quarter")
plt.ylabel("Revenue")
plt.tight_layout()
plt.show()


