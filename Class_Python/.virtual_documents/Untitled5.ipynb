# Line Chart
import matplotlib.pyplot as plt
days=[1,2,3,4,5]
sales=[100,120,140,130,160]
plt.plot(days,sales)
plt.show()


import matplotlib.pyplot as plt
categories = ["A", "B", "C"]
values = [30, 45, 25]
plt.bar(categories, values)
plt.show()


import matplotlib.pyplot as plt
labels = ["Q1", "Q2", "Q3"]
sales_2024 = [20, 35, 30]
sales_2025 = [25, 30, 40]
x = range(len(labels))
plt.bar(x, sales_2024, label="2024")
plt.bar(x, sales_2025, bottom=sales_2024, label="2025")
plt.legend()
plt.show()


import matplotlib.pyplot as plt
categories = ["Product A", "Product B", "Product C"]
values = [50, 70, 40]
plt.barh(categories, values)
plt.show()


import matplotlib.pyplot as plt
