import matplotlib.pyplot as plt

x = [1, 2, 3, 4]
y = [10, 20, 15, 25]

plt.plot(x, y)
plt.show()


import matplotlib.pyplot as plt

x = [1, 2, 3, 4]
y1 = [10, 20, 30, 40]
y2 = [15, 25, 35, 45]

plt.plot(x, y1)
plt.plot(x, y2)
plt.show()


import matplotlib.pyplot as plt

x = [1, 2, 3, 4]
y = [5, 10, 15, 20]

plt.plot(x, y, marker='o')
plt.show()


import matplotlib.pyplot as plt

x = [1, 2, 3, 4]
y = [10, 20, 30, 40]

plt.plot(x, y, linestyle='-.', color='red')
plt.show()


import matplotlib.pyplot as plt

x = [1, 2, 3, 4]
y = [2, 4, 6, 8]

plt.plot(x, y)
plt.xlabel("X Values")
plt.ylabel("Y Values")
plt.title('Understanding X and Y Axis')
plt.show()


import matplotlib.pyplot as plt
fig, ax = plt.subplots()
ax.plot([1, 2, 3], [4, 5, 6])
plt.show()


import matplotlib.pyplot as plt
fig, axes = plt.subplots(2, 1)
plt.show()


import matplotlib.pyplot as plt
plt.figure()
plt.plot([1, 2, 3], [3, 2, 1])
plt.show()


import matplotlib.pyplot as plt
fig, ax = plt.subplots()
ax.plot([1, 2, 3], [3, 2, 1])
plt.show()


import matplotlib.pyplot as plt
plt.figure(figsize=(8, 4))
plt.plot([1, 2, 3], [10, 20, 30])
plt.show()


import matplotlib.pyplot as plt
fig, axes = plt.subplots(2, 2)
plt.show()


import matplotlib.pyplot as plt
fig, axes = plt.subplots(2, 1, sharex=True)
axes[0].plot([1, 2, 3], [10, 20, 30])
axes[1].plot([1, 2, 3], [5, 15, 25])
plt.show()



