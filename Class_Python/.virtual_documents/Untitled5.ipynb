import matplotlib.pyplot as plt
import datetime
dates = []
for d in range(1,5):
    dates.append(datetime.date(2025,1,d))
values = [100, 120, 140, 160]
plt.plot(dates, values)
plt.show()


import matplotlib.pyplot as plt
x = [1, 2, 3, 4]
y = [10, 20, 30, 40]
plt.plot(x, y)
plt.annotate("Peak", xy=(4, 40), xytext=(3, 30), arrowprops=dict(arrowstyle="->"))
plt.show()


import matplotlib.pyplot as plt
x = [1, 2, 3, 4]
y = [10, 20, 30, 40]
plt.plot(x, y)
plt.scatter([3,4], [30,40], color="red")
plt.show()


import matplotlib.pyplot as plt
x = [1, 2, 3, 4]
y1 = [10, 20, 30, 40]
y2 = [100, 200, 300, 400]
fig, ax1 = plt.subplots()
ax2 = ax1.twinx()
ax1.plot(x, y1,color='red',linestyle='--',marker='o')
ax2.plot(x, y2,color='green',linestyle=':',marker='s')
plt.show()


import matplotlib.pyplot as plt
x = [1, 2, 3, 4]
y = [10, 100, 1000, 10000]
plt.plot(x, y)
plt.yscale("log")
plt.show()


import matplotlib.pyplot as plt
