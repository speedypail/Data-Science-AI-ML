import pandas as pd

date_range = pd.date_range(
    start='2023-01-01',
    periods=6,
    freq='D'
)

df = pd.DataFrame(
    {'sales': [100, 200, 150, 300, 250, 400]},
    index=date_range
)

monthly = df.resample('ME').sum()

print(monthly)



