import pandas as pd
data = {'Name': ['Alice', 'Bob', 'Charlie'], 'Marks': [85, None, 78]}
df = pd.DataFrame(data)
df_filled = df.fillna(0)
print(df_filled)


import pandas as pd
data = {'Name': ['Alice', 'Bob', 'Charlie'], 'Marks': [85, None, 78]}
df = pd.DataFrame(data)
df_dropped = df.dropna()
