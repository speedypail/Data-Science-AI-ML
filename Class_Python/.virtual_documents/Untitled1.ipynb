import pandas as pd
data = {'Name': ['Alice', 'Bob', 'Charlie'], 'Grade': ['A', 'B', 'F']}
df = pd.DataFrame(data)
df_replaced = df.replace({'F': 'Fail'})
print(df_replaced)


