import pandas as pd

arrays = [
    ["India", "India", "USA", "USA"],
    ["2023", "2024", "2023", "2024"]
]

index = pd.MultiIndex.from_arrays(arrays, names=("Country", "Year"))

df = pd.DataFrame({"Sales": [100, 120, 90, 110]}, index=index)
print(df)


