import pandas as pd

df = pd.DataFrame({
    "Name": ["Asha", "Ravi", "Kiran", "Meera", "Vikram"],
    "Age": [24, 30, 28, 26, 32],
    "Gender": ["Female", "Male", "Male", "Female", "Male"],
    "Department": ["HR", "IT", "IT", "Finance", "HR"]
})

df["Gender"] = df["Gender"].astype("category")

print(df)
print(df.dtypes)


