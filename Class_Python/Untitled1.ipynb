   ],
   "source": [
    "import pandas as pd\n",
    "df = pd.DataFrame({\n",
    "    \"Department\": [\"IT\", \"HR\", \"IT\", \"HR\"],\n",
    "    \"Salary\": [50000, 40000, 55000, 42000]\n",
    "})\n",
    "df[\"Dept_Avg_Salary\"] = df.groupby(\"Department\")[\"Salary\"].transform(\"mean\")\n",
    "print(df)"
   ]
  },
