# Task 6
import sqlite3
conn = sqlite3.connect("school.db")
with open("students.sql", "r") as file:
    sql_script=file.read()
conn.executescript(sql_script)
df=pd.read_sql("SELECT * FROM students", conn)
print(df)
conn.close()



