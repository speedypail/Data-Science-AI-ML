# Part A
import pandas as pd
subjects=['Maths','Science','English','Computer']
marks=[85,78,90,88]
series=pd.Series(marks,subjects)
print(series)
maximum=series.max()
print(f"The highest marks is: {maximum}")
minimum=series.min()
print(f"The lowest marks is: {minimum}")
total=series.sum()
print(f"The total marks is: {total}")
average=series.mean()
print(f"The average marks is: {average}")


