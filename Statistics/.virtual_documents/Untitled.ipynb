import matplotlib.pyplot as plt
marks = [45, 50, 50, 60, 60, 60, 70, 80, 90, 90]
plt.hist(marks,bins=5)
plt.xlabel('Marks')
plt.ylabel('Frequency')
plt.title('Marks Distribution of the student')
plt.show()


print('The most marks scored by the students is 60 which has a frequeny of 3 which means marks is concentrated around 60')


print('The data is not evenly spread. Most of the marks are concentrated around 60, making 60 the most frequent mark (mode).')



